	"authors": [
		"Me!"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/void-expansion/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.zacharybarbanell.voidexpansion.VoidExpansion"
		],
